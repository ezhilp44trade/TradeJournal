{
  "rules": {
    "allowlist": {
      ".read": false,
      ".write": false,
      "$emailKey": {
        ".read": "auth != null && auth.token.email != null && $emailKey === auth.token.email.toLowerCase().replace('.', ',')"
      }
    },
    "profiles": {
      ".read": "auth != null && root.child('allowlist').child(auth.token.email.toLowerCase().replace('.', ',')).val() === true",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid && root.child('allowlist').child(auth.token.email.toLowerCase().replace('.', ',')).val() === true"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && root.child('allowlist').child(auth.token.email.toLowerCase().replace('.', ',')).val() === true",
        ".write": "auth != null && auth.uid === $uid && root.child('allowlist').child(auth.token.email.toLowerCase().replace('.', ',')).val() === true"
      }
    }
  }
}
